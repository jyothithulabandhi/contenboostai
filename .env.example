# ContentBoost AI - Environment Variables
# Copy this file to .env and fill in your API keys

# Anthropic Claude API Key (required for LLM optimization)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# Firecrawl API Key (required for competitor scraping)
# Get yours at: https://firecrawl.dev
FIRECRAWL_API_KEY=your-firecrawl-api-key

# Mem0 API Key (required for memory-based learning)
# Get yours at: https://app.mem0.ai
MEM0_API_KEY=your-mem0-api-key
